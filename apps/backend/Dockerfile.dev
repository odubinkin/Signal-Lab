# Dev image for the backend service.
# node_modules and source live in image layers; only mutable source dirs are
# bind-mounted at runtime for hot reload (see docker-compose.yml).
# When package.json/package-lock.json or non-source files change, run
# `docker compose build backend`.
FROM node:22-bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends openssl ca-certificates procps \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY package.json package-lock.json ./
COPY prisma ./prisma
COPY apps/backend/package.json ./apps/backend/package.json
COPY apps/frontend/package.json ./apps/frontend/package.json

RUN npm ci

COPY apps/backend ./apps/backend

EXPOSE 3001

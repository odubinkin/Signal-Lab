# Dev image for the backend service.
# Bakes `npm ci` so node_modules lives in the image layer; source is bind-mounted
# from the host at runtime to keep hot reload working.
# When package.json or package-lock.json changes, run `docker compose build backend`.
FROM node:22-bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends openssl ca-certificates procps \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY package.json package-lock.json ./
COPY prisma ./prisma
COPY apps/backend/package.json ./apps/backend/package.json
COPY apps/frontend/package.json ./apps/frontend/package.json

RUN npm ci

EXPOSE 3001

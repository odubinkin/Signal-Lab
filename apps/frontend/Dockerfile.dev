# Dev image for the frontend service.
# Bakes `npm ci` so node_modules lives in the image layer; source is bind-mounted
# from the host at runtime to keep Next.js hot reload working.
# When package.json or package-lock.json changes, run `docker compose build frontend`.
FROM node:22-bookworm-slim

WORKDIR /workspace

COPY package.json package-lock.json ./
COPY prisma ./prisma
COPY apps/backend/package.json ./apps/backend/package.json
COPY apps/frontend/package.json ./apps/frontend/package.json

RUN npm ci

EXPOSE 3000

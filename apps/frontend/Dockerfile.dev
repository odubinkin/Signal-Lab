# Dev image for the frontend service.
# node_modules and source live in image layers; only mutable source dirs are
# bind-mounted at runtime for Next.js hot reload (see docker-compose.yml).
# When package.json/package-lock.json or non-source files (next.config.ts,
# postcss.config.mjs, tailwind, tsconfig) change, run
# `docker compose build frontend`.
FROM node:22-bookworm-slim

WORKDIR /workspace

COPY package.json package-lock.json ./
COPY prisma ./prisma
COPY apps/backend/package.json ./apps/backend/package.json
COPY apps/frontend/package.json ./apps/frontend/package.json

RUN npm ci

COPY apps/frontend ./apps/frontend

EXPOSE 3000

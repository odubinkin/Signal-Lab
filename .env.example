# PostgreSQL container settings.
# Used by the postgres service to initialize the local development database.
POSTGRES_USER=signal_lab
POSTGRES_PASSWORD=signal_lab
POSTGRES_DB=signal_lab

# Host port for connecting to PostgreSQL from your machine.
# Change this if localhost:5432 is already in use; containers still use postgres:5432.
POSTGRES_PORT=5432

# Backend database connection string.
# Inside Docker, keep host=postgres and port=5432 because services communicate on the Compose network.
DATABASE_URL=postgresql://signal_lab:signal_lab@postgres:5432/signal_lab?schema=public

# Backend service settings.
# BACKEND_PORT is the internal port Nest listens on inside the backend container.
BACKEND_PORT=3001

# BACKEND_HOST_PORT is the port exposed on your machine, e.g. http://localhost:3001.
# Change this if localhost:3001 is already in use without changing BACKEND_PORT.
BACKEND_HOST_PORT=3001

# Artificial delay for the slow_request scenario, in milliseconds.
SLOW_REQUEST_TIMEOUT_MS=5000

# Optional Sentry DSN. Leave empty to disable Sentry event delivery in local development.
SENTRY_DSN=

# Frontend service settings.
# Port exposed on your machine for the Next.js app.
FRONTEND_PORT=3000

# Browser-visible backend API URL used by the frontend.
# If BACKEND_HOST_PORT changes, update this URL to match the exposed host port.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

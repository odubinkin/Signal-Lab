# PostgreSQL container settings.
# Used by the postgres service to initialize the local development database.
POSTGRES_USER=signal_lab
POSTGRES_PASSWORD=signal_lab
POSTGRES_DB=signal_lab

# Host port for connecting to PostgreSQL from your machine.
# Change this if localhost:5432 is already in use; containers still use postgres:5432.
POSTGRES_PORT=5432

# Backend database connection string.
# Inside Docker, keep host=postgres and port=5432 because services communicate on the Compose network.
DATABASE_URL=postgresql://signal_lab:signal_lab@postgres:5432/signal_lab?schema=public

# Backend service settings.
# BACKEND_PORT is the internal port Nest listens on inside the backend container.
BACKEND_PORT=3001

# Artificial delay for the slow_request scenario, in milliseconds.
SLOW_REQUEST_TIMEOUT_MS=5000

# Optional Sentry DSN. Leave empty to disable Sentry event delivery in local development.
SENTRY_DSN=

# Optional Sentry dashboard link parts for frontend observability links.
SENTRY_BASE_URL=https://sentry.io
SENTRY_ORG_SLUG=
SENTRY_PROJECT_SLUG=signal-lab

# Frontend service settings.
# Port exposed on your machine for the Next.js app.
FRONTEND_PORT=3000

# Browser-visible backend API URL used by the frontend.
# If BACKEND_PORT changes, update this URL to match the exposed host port.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# Browser-visible observability service URLs used by the frontend links block.
NEXT_PUBLIC_GRAFANA_BASE_URL=http://localhost:3100
NEXT_PUBLIC_PROMETHEUS_BASE_URL=http://localhost:9090

# Run history auto-refresh interval in seconds for the frontend.
NEXT_PUBLIC_RUN_HISTORY_REFRESH_SECONDS=5

# Observability stack host ports.
# PROMETHEUS_PORT exposes the Prometheus UI/API on your machine.
PROMETHEUS_PORT=9090

# GRAFANA_PORT exposes Grafana on your machine. Inside Docker Grafana stays on 3000.
GRAFANA_PORT=3100

# LOKI_PORT exposes the Loki HTTP API on your machine for ad-hoc curl queries.
# Grafana, Promtail, and the backend never use this host port; they reach Loki through the compose network at loki:3100.
LOKI_PORT=3102

# Default Grafana admin credentials (anonymous viewer access is also enabled for the demo).
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
